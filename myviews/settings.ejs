                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=formData.enableCustomPictures ? 'checked' : '' %><%}else{%><%=(settings.enableCustomPictures == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="enableCustomPictures">Enabled</label>
                    <small id="enableCustomPicturesHelp" class="form-text text-muted">(Uses .jpg files placed in './posterr/custom' folder)</small>
                  </div>
                </div>

              <div class="form-group">
                <label class="my-1 mr-2" for="inlineFormCustomSelectPref">Theme Folder(s)</label>
                <select class="custom-select my-1 mr-sm-2" name="customPictureTheme" id="customPictureTheme" multiple size="6">
                  <% customPicFolders.forEach(function(fld) { %>
                    <option value="<%=fld%>"><%=fld%></option>>
                  <% }); %>
                </select>
                <small class="form-text text-muted">Hold Ctrl (or Cmd on Mac) to select multiple folders.</small>
              </div>
              <div class="form-group border rounded p-3">
                <label for="customPictureUploadFile">Upload new custom image</label>
                <input type="file" class="form-control-file mb-2" id="customPictureUploadFile" accept=".jpg,.jpeg,.png,.gif,.webp,image/jpeg,image/png,image/gif,image/webp">
                <label for="customPictureNewFolder">Create new folder (optional)</label>
                <input type="text" class="form-control mb-2" id="customPictureNewFolder" placeholder="Example: halloween">
                <small class="form-text text-muted mb-2">If a new folder is provided, the image uploads there. Otherwise it uploads to the selected Theme Folder.</small>
                <button type="button" class="btn btn-outline-primary btn-sm" id="customPictureUploadBtn">Upload image</button>
              </div>
              <div class="form-group">
                <label for="customPictureEveryPosters">Show custom picture after this many posters</label>
                <input type="number" min="0" step="1" class="form-control" id="customPictureEveryPosters" name="customPictureEveryPosters"
                  value="<% if(typeof formData !== 'undefined' && errors){%><%=formData.customPictureEveryPosters !== undefined ? formData.customPictureEveryPosters : 0%><%}else{%><%=settings.customPictureEveryPosters !== undefined ? settings.customPictureEveryPosters : 0%><%}%>">
                <small class="form-text text-muted">0 disables spacing. Example: 5 means one custom picture appears after every 5 poster slides.</small>
              </div>
              <script lang='javascript'>
                    // set pre-selected folder(s)
                    var picTheme = document.getElementById("customPictureTheme");
                  <%
                    var _selectedThemesRaw = (typeof formData !== 'undefined' && errors)
                      ? formData.customPictureTheme
                      : settings.customPictureTheme;
                  %>
                    var selectedThemes = String(<%- JSON.stringify(_selectedThemesRaw || "") %> || "")
                      .split(',')
                      .map(function (v) { return v.trim(); })
                      .filter(Boolean);
                    if (!selectedThemes.length) selectedThemes = ["default"];
                    for (var i = 0; i < picTheme.options.length; i++) {
                      picTheme.options[i].selected = selectedThemes.indexOf(picTheme.options[i].value) >= 0;
                    }
                    var uploadBtn = document.getElementById("customPictureUploadBtn");
                    if (uploadBtn) {
                      uploadBtn.addEventListener("click", function () {
                        var fileInput = document.getElementById("customPictureUploadFile");
                        var folderInput = document.getElementById("customPictureNewFolder");
                        var selectedTheme = document.getElementById("customPictureTheme");
                        if (!fileInput || !fileInput.files || !fileInput.files.length) {
                          alert("Please choose an image file first.");
                          return;
                        }
                        var selectedValues = [];
                        if (selectedTheme && selectedTheme.options) {
                          for (var i = 0; i < selectedTheme.options.length; i++) {
                            if (selectedTheme.options[i].selected) selectedValues.push(selectedTheme.options[i].value);
                          }
                        }
                        var fd = new FormData();
                        fd.append("customPictureUpload", fileInput.files[0]);
                        fd.append("customPictureTheme", selectedValues.length ? selectedValues[0] : "default");
                        fd.append("customPictureNewFolder", folderInput ? folderInput.value : "");
                        fetch("<%=baseUrl%>/settings/custom-pictures/upload", {
                          method: "POST",
                          body: fd,
                          credentials: "same-origin"
                        }).then(function () {
                          window.location.reload();
                        }).catch(function (err) {
                          alert(err && err.message ? err.message : "Upload failed");
                        });
                      });
                    }
                  </script>
               </div>
              </div>
            </div>
