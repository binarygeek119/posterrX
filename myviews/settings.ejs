-->

<head>
  <meta charset="utf-8">
  <meta http-equiv="Cache-control" content="public">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

  <!-- Additional js libs -->
  <!-- <script src="<%=baseUrl%>/js/jquery-3.3.1.slim.min.js"></script> -->
  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.9/umd/popper.min.js" integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q" crossorigin="anonymous"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
  <!-- <script src="<%=baseUrl%>/js/bootstrap-colourpicker.min.js"></script> -->
  <script src="/js/iro.min.js"></script>

  <!--- CSS -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.4.1/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="<%=baseUrl%>/css/settings-styles.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/light.min.css">
  <link rel="stylesheet" href="<%=baseUrl%>/css/font-awesome.min.css">
  <!-- <link rel="stylesheet" href="<%=baseUrl%>/css/bootstrap-colourpicker.min.css"> -->
  <!-- <script src="/js/script.js"></script> -->

  <title>PosterX - Settings</title>
  <link rel="shortcut icon" type="image/png" href="<%=baseUrl%>/favicons/favicon.ico" />
</head>

<body>

  <%if(!user.valid){%><script language='javascript'>
    window.location.href = '<%=baseUrl%>/logon';
  </script>%><%}%>
  <%- include('new-features-banner.ejs') %>
  <div class="container">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="main-breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="<%=baseUrl%>/">PosterX</a></li>
  <li class="breadcrumb-item active" aria-current="page">PosterX Settings</li>
  </ol>
  </nav>
  <% if (typeof showNewFeaturesBanner !== 'undefined' && showNewFeaturesBanner && user && user.valid) { %>
  <div class="card border-danger mb-3">
    <div class="card-body">
      <p class="mb-2">PosterX <strong>v<%= typeof appVersion !== 'undefined' ? appVersion : '' %></strong> includes changes you have not acknowledged yet. The red banner appears on the main display and other pages until you confirm below.</p>
      <form method="post" action="<%= baseUrl %>/settings/new-features-acknowledge">
        <button type="submit" class="btn btn-danger">Acknowledge there are new features</button>
      </form>
    </div>
  </div>
  <% } %>
  <%if(typeof formData !== 'undefined' && formData.saved == true) {%><script language='javascript'>
    alert("PosterX Settings Saved. Please allow a few seconds for PosterX to restart.");
  </script><%}%>
  <%if(typeof cacheClearNotice !== 'undefined' && cacheClearNotice && cacheClearNotice.text) {%><script>
    alert(<%- JSON.stringify(cacheClearNotice.text) %>);
  </script><%}%>
    <!-- Layout -->
    <div class="row gutters-sm">
      <!-- Side Menu View -->
      <div class="col-md-4 d-none d-md-block">
        <div class="card">
          <div class="card-body">
            <nav class="nav flex-column nav-pills nav-gap-y-1">
              <a href="#settings" data-toggle="tab" class="nav-item nav-link has-icon nav-link-faded active">
                <i class="fal fa-cog"></i><span class="menu">Settings</span>
              </a>
              <a href="<%=baseUrl%>/settings/sync" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-sync"></i><span class="menu">Sync</span>
              </a>
              <a href="<%=baseUrl%>/settings/now-showing" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-film"></i><span class="menu">Now Showing</span>
              </a>
              <a href="<%=baseUrl%>/settings/ads" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-bullhorn"></i><span class="menu">Ads</span>
              </a>
              <a href="<%=baseUrl%>/settings/holidays" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-snowflake"></i><span class="menu">Holidays</span>
              </a>
              <a href="<%=baseUrl%>/settings/tmdb-api" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-key"></i><span class="menu">TMDB API</span>
              </a>
              <a href="<%=baseUrl%>/settings/cache" class="nav-item nav-link has-icon nav-link-faded">
                <i class="fal fa-database"></i><span class="menu">Cache</span>
              </a>
              <a href="<%=baseUrl%>/debug" class="nav-item nav-link has-icon nav-link-faded">
  <i class="fal fa-debug"></i><span class="menu">Debug</span>
  </a>
  <a href="#about" data-toggle="tab" class="nav-item nav-link has-icon nav-link-faded">
    <i class="fal fa-person-sign"></i><span class="menu">About</span>
  </a>
  </nav>
  </div>
  </div>
  </div>


  <div class="col-md-8">
    <div class="card">
      <div class="d-none d-md-flex border-bottom py-2 px-3 justify-content-end align-items-center flex-wrap">
        <a href="#collapseFive" class="nav-link has-icon text-body py-1 mr-3" data-toggle="collapse" data-target="#collapseFive"><i class="fal fa-play"></i><span class="menu">Now Playing</span></a>
        <a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon text-body py-1"><i class="fal fa-film"></i><span class="menu">Now Showing settings</span></a>
      </div>
      <!-- Mobile Menu View -->
      <div class="card-header border-bottom mb-3 d-flex d-md-none">
        <ul class="nav nav-tabs card-header-tabs nav-gap-x-1" role="tablist">
          <li class="nav-item">
            <a href="#settings" data-toggle="tab" class="nav-link has-icon active"><i class="fal fa-cog"></i>
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle></svg>
            </a>
          </li>
          <li class="nav-item">
            <a href="<%=baseUrl%>/settings/sync" class="nav-link has-icon"><i class="fal fa-sync"></i></a>
          </li>
          <li class="nav-item">
            <a href="<%=baseUrl%>/settings/cache" class="nav-link has-icon"><i class="fal fa-database"></i></a>
          </li>
          <li class="nav-item">
            <a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon"><i class="fal fa-film"></i></a>
          </li>
          <li class="nav-item">
            <a href="<%=baseUrl%>/settings/ads" class="nav-link has-icon"><i class="fal fa-bullhorn"></i></a>
          </li>
          <li class="nav-item">
            <a href="<%=baseUrl%>/settings/holidays" class="nav-link has-icon"><i class="fal fa-snowflake"></i></a>
          </li>
          <li class="nav-item">
            <a href="#collapseFive" class="nav-link has-icon" data-toggle="collapse" data-target="#collapseFive"><i class="fal fa-play"></i></a>
          </li>
          <li class="nav-item">
            <a href="<%=baseUrl%>/settings/now-showing" class="nav-link has-icon"><i class="fal fa-film"></i></a>
          </li>
          <li class="nav-item">
            <a href="<%=baseUrl%>/settings/tmdb-api" class="nav-link has-icon"><i class="fal fa-key"></i></a>
          </li>
          <li class="nav-item">
            <a href="<%=baseUrl%>/debug" class="nav-link has-icon"><i class="fal fa-debug"></i>
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
            </a>
          </li>
          <li class="nav-item ml-auto">
            <a href="#about" data-toggle="tab" class="nav-link has-icon"><i class="fal fa-person-sign"></i>
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
              </svg>
            </a>
          </li>
        </ul>

      </div>
      <% if(latestVersion !== undefined && latestVersion !== "" && latestVersion !== version.toString() && (typeof errors == 'undefined' || errors.length == 0) && updateAvailable == true){%>
      <p id="rcorners-u"><span id="message">Update</span><br>Please upgrade to PosterX v<%=latestVersion%></br>
      <%}%>

                  <!-- show validation errors -->
                  <% 
              if(typeof errors !== 'undefined' && errors.length > 0){
                // display validation errors
                %><p id="rcorners-e"><span id="message">Validation errors</span><br><%
                errors.forEach(function(e) { %>
                  <%=e.msg %></br>
                  <%});%></p>
                  <%}%>


      <!-- Tab Content -->
      <div class="card-body tab-content">

        <!-- General Settings -->
        <div class="tab-pane active" id="settings">


          <div class="panel-group accordion" id="accordion" name="accordion" role="tablist" aria-multiselectable="true">
            <div class="panel panel-default">
              <div class="panel-heading" role="tab" id="headingOne">
                <h4 class="panel-title">
                  <a class="collapsed" data-toggle="collapse" data-parent="#accordion" href="#collapseOne"
                    aria-expanded="false" aria-controls="collapseOne">
                    GENERAL SETTINGS <i class="accordion_icon fal fa-plus"></i>
                  </a>
                </h4>
              </div>
              <div id="collapseOne" class="panel-collapse collapse" role="tabpanel" aria-labelledby="headingOne">
                <div class="panel-body">

              <form method="POST" action="<%=baseUrl%>/settings">
                  <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" class="form-control" id="password" name="password"
                      aria-describedby="password" placeholder="Enter a password"
                      value="<% if(typeof formData !== 'undefined' && errors){%><%=formData.password%>" <%}else{%><%=settings.password%>"<%}%>>
                  <small id="passwordHelp" class="form-text text-muted">Enter a password to secure this page</small>
                </div>
                <div class="form-group">
                  <label for="slideDuration">Slide Duration</label>
                  <input type="text" class="form-control" id="slideDuration" name="slideDuration" aria-describedby="slideDuration"
                    placeholder="Suggest no less than 5 and no more than 20-30 seconds" value="<% if(typeof formData !== 'undefined' && errors){%><%=formData.slideDuration%>"<%}else{%><%=settings.slideDuration%>"<%}%>>
                  <small id="slideDurationHelp" class="form-text text-muted">How many seconds that each slide will
                    remain on the screen</small>
                </div>

                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="artSwitch" id="artSwitch" 
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=formData.artSwitch ? 'checked' : '' %><%}else{%><%=(settings.hasArt == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="artSwitch">Enable background artwork</label>
                    <small id="themeHelp" class="form-text text-muted">Shows background art (if available)</small>
                  </div>
                </div>

                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="showCast" id="showCast"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.showCast == 'true' || formData.showCast === true) ? 'checked' : '' %><%}else{%><%=(settings.showCast == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="showCast">Show cast (actors) — coming soon ™</label>
                    <small class="form-text text-muted">Shows principal cast on cards when the media server provides it (Plex, Jellyfin, Emby).</small>
                  </div>
                </div>

                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="showDirectors" id="showDirectors"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.showDirectors == 'true' || formData.showDirectors === true) ? 'checked' : '' %><%}else{%><%=(settings.showDirectors == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="showDirectors">Display directors — coming soon ™</label>
                    <small class="form-text text-muted">Shows director names on cards when the media server provides them (Plex, Jellyfin, Emby).</small>
                  </div>
                </div>

                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="showAuthors" id="showAuthors"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.showAuthors == 'true' || formData.showAuthors === true) ? 'checked' : '' %><%}else{%><%=(settings.showAuthors == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="showAuthors">Show authors — coming soon ™</label>
                    <small class="form-text text-muted">Shows author names on book cards from Readarr/Chaptarr and on Jellyfin/Emby ebooks and audiobooks when metadata includes them.</small>
                  </div>
                </div>

                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="showAlbumArtist" id="showAlbumArtist"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.showAlbumArtist == 'true' || formData.showAlbumArtist === true) ? 'checked' : '' %><%}else{%><%=(settings.showAlbumArtist == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="showAlbumArtist">Display artist — coming soon ™</label>
                    <small class="form-text text-muted">Shows artist names on music album and track cards (Plex, Jellyfin, Emby, Kodi), on-demand albums, and Lidarr coming-soon albums when available.</small>
                  </div>
                </div>

                <label class="d-block">Display posters &amp; portraits</label>
                <p class="small text-muted">Main music cover and small corner portraits when the media server provides images. Background artwork still follows <strong>Enable background artwork</strong> above.</p>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="displayPosterAlbum" id="displayPosterAlbum"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.displayPosterAlbum == 'true' || formData.displayPosterAlbum === true) ? 'checked' : '' %><%}else{%><%=(settings.displayPosterAlbum == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="displayPosterAlbum">Display albums — coming soon ™</label>
                    <small class="form-text text-muted">Shows album/track cover art as the main poster (movie/TV style) with music metadata in the bottom banner. When off, music cards use a placeholder image.</small>
                  </div>
                </div>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="displayPosterVideo" id="displayPosterVideo"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.displayPosterVideo == 'true' || formData.displayPosterVideo === true) ? 'checked' : '' %><%}else{%><%=((settings.displayPosterVideo == 'true') || (settings.displayPosterVideo === true) || (settings.displayPosterVideo == 'on') || (settings.displayPosterVideo == 1) || (settings.displayPosterVideo == '1')) ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="displayPosterVideo">Display movie and TV posters</label>
                    <small class="form-text text-muted">Shows posters for movies and TV (shows/episodes). When off, video cards use a placeholder image.</small>
                  </div>
                </div>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="displayPosterBooks" id="displayPosterBooks"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.displayPosterBooks == 'true' || formData.displayPosterBooks === true) ? 'checked' : '' %><%}else{%><%=(settings.displayPosterBooks == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="displayPosterBooks">Display books and audiobooks — coming soon ™</label>
                    <small class="form-text text-muted">Shows ebook/audiobook cover art as the main poster (movie/TV style) with book metadata in the bottom banner. When off, book cards use a placeholder image.</small>
                  </div>
                </div>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="displayPosterCast" id="displayPosterCast"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.displayPosterActor == 'true' || formData.displayPosterActress == 'true' || formData.displayPosterCast) ? 'checked' : '' %><%}else{%><%=(settings.displayPosterActor == 'true' || settings.displayPosterActress == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="displayPosterCast">Display actors and actresses — coming soon ™</label>
                    <small class="form-text text-muted">Shows cast portraits when available (Plex, Jellyfin, Emby).</small>
                  </div>
                </div>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="displayPosterDirector" id="displayPosterDirector"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.displayPosterDirector == 'true' || formData.displayPosterDirector === true) ? 'checked' : '' %><%}else{%><%=(settings.displayPosterDirector == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="displayPosterDirector">Display director portrait — coming soon ™</label>
                    <small class="form-text text-muted">Shows a director image when available.</small>
                  </div>
                </div>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="displayPosterAuthor" id="displayPosterAuthor"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.displayPosterAuthor == 'true' || formData.displayPosterAuthor === true) ? 'checked' : '' %><%}else{%><%=(settings.displayPosterAuthor == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="displayPosterAuthor">Show author portrait — coming soon ™</label>
                    <small class="form-text text-muted">Writer/author person image when the server provides it (Plex Writer thumb; Jellyfin/Emby People).</small>
                  </div>
                </div>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="displayPosterArtist" id="displayPosterArtist"
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=(formData.displayPosterArtist == 'true' || formData.displayPosterArtist === true) ? 'checked' : '' %><%}else{%><%=(settings.displayPosterArtist == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="displayPosterArtist">Display artist portrait — coming soon ™</label>
                    <small class="form-text text-muted">Shows an artist image when metadata includes it (for example Plex grandparent/parent thumb or Jellyfin album artist image).</small>
                  </div>
                </div>

                <label class="d-block">Theme Options</label>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="themeSwitch" id="themeSwitch" 
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=formData.themeSwitch ? 'checked' : '' %><%}else{%><%=(settings.playThemes == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="themeSwitch">TV themes</label>
                    <small id="themeHelp" class="form-text text-muted">Enables TV theme (if available)</small>
                  </div>
                </div>

                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="genericSwitch" id="genericSwitch" 
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=formData.genericSwitch ? 'checked' : '' %><%}else{%><%=(settings.genericThemes == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="genericSwitch">Movie themes</label>
                    <small id="randomThemeHelp" class="form-text text-muted">Enables movie themes (if available)</small>
                  </div>
                </div>

                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="enableCustomPictureThemes" id="enableCustomPictureThemes" 
                      value="true" <% if(typeof formData !== 'undefined' && errors){%><%=formData.enableCustomPictureThemes ? 'checked' : '' %><%}else{%><%=(settings.enableCustomPictureThemes == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="enableCustomPictureThemes">Custom picture themes</label>
                    <small id="enableCustomPictureThemesHelp" class="form-text text-muted">Enables custom picture themes (if available)</small>
                  </div>
                </div>

                
                <label class="d-block">Slide Transitions</label>
                <div class="form-group">
                  <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="fadeOption" id="slideRadio" value="false" 
                    <% if(typeof formData !== 'undefined' && errors){%><%=(formData.fadeOption=='false') ? 'checked' : '' %><%}else{%><%=(settings.fade == 'false') ? 'checked' : '' %><%}%>>
                    <label class="form-check-label" for="slideRadio">Slide</label>
                  </div>
                  <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="fadeOption" id="fadeOption" value="true" 
                    <% if(typeof formData !== 'undefined' && errors){%><%=(formData.fadeOption=='true') ? 'checked' : '' %><%}else{%><%=(settings.fade == 'true') ? 'checked' : '' %><%}%>>
                    <label class="form-check-label" for="fadeRadio">Fade</label>
                  </div>
                  <small id="fadeRadioHelp" class="form-text text-muted">The transition effect for when slides
                    change</small>
                  <div class="form-group small text-muted">
                  </div>
                </div>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="shuffleSwitch" id="shuffleSwitch"
                     value="true" <% if(typeof formData !== 'undefined' && errors){%><%=formData.shuffleSwitch ? 'checked' : '' %><%}else{%><%=(settings.shuffleSlides == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="shuffleSwitch">Shuffle slides</label>
                    <small id="suffleSwitchHelp" class="form-text text-muted">Shuffles on-demand, coming soon (Radarr, Sonarr, Lidarr, Readarr)</small>
                  </div>
                </div>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="hideSettingsLinks" id="hideSettingsLinks"
                     value="true" <% if(typeof formData !== 'undefined' && errors){%><%=formData.hideSettingsLinks ? 'checked' : '' %><%}else{%><%=(settings.hideSettingsLinks == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="hideSettingsLinks">Remove settings links</label>
                    <small id="hideSettingsLinksHelp" class="form-text text-muted">Removes all settings links. (You must type in /settings)</small>
                  </div>
                </div>
                <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="theaterRoomMode" id="theaterRoomMode"
                     value="true" <% if(typeof formData !== 'undefined' && errors){%><%=formData.theaterRoomMode ? 'checked' : '' %><%}else{%><%=(settings.theaterRoomMode == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="theaterRoomMode">Theatre room mode</label>
