            <div class="panel panel-default">
              <div class="panel-heading" role="tab" id="headingThree">
                <h4 class="panel-title">
                  <a class="collapsed" data-toggle="collapse" data-parent="#accordion" href="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                    MEDIA SERVER (PLEX / JELLYFIN / EMBY / KODI) <i class="accordion_icon fal fa-plus"></i>
                  </a>
                </h4>
              </div>
              <div id="collapseThree" class="panel-collapse collapse" role="tabpanel" aria-labelledby="headingThree">
                <div class="panel-body">

                  <div class="form-group">
                    <label for="mediaServerType">Server type</label>
                    <select class="custom-select" name="mediaServerType" id="mediaServerType">
                      <% var _mst = (typeof formData !== 'undefined' && errors && formData.mediaServerType) ? formData.mediaServerType : (settings.mediaServerType || 'plex'); %>
                      <option value="plex" <% if (_mst === 'plex') { %>selected<% } %>>Plex</option>
                      <option value="jellyfin" <% if (_mst === 'jellyfin') { %>selected<% } %>>Jellyfin</option>
                      <option value="emby" <% if (_mst === 'emby') { %>selected<% } %>>Emby</option>
                      <option value="kodi" <% if (_mst === 'kodi') { %>selected<% } %>>Kodi</option>
                    </select>
                    <small class="form-text text-muted">Jellyfin/Emby: API key in server dashboard. Kodi: enable <strong>Settings → Services → Control → Allow remote control via HTTP</strong>; use JSON-RPC port (often 8080). Token: leave blank if no login, or <code>password</code> / <code>username:password</code> for HTTP auth.</small>
                  </div>

                  <div class="form-group">
                  <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                    <input type="checkbox" class="custom-control-input" name="plexHTTPSSwitch" id="plexHTTPSSwitch"
                     value="true" <% if(typeof formData !== 'undefined' && errors){%><%=formData.plexHTTPSSwitch ? 'checked' : '' %><%}else{%><%=(settings.plexHTTPS == 'true') ? 'checked' : '' %><%}%>>
                    <label class="custom-control-label" for="plexHTTPSSwitch">HTTPS Connection</label>
                    <small id="plexHTTPSHelp" class="form-text text-muted">Enable if your media server only allows HTTPS.</small>
                  </div>
                </div>

                <div class="form-group">
                  <label for="plexIP">Server IP or Domain Name</label>
                  <input type="text" class="form-control" id="plexIP" name="plexIP" aria-describedby="plexIPHelp"
                    placeholder="n.n.n.n" value="<% if(typeof formData !== 'undefined' && errors){%><%=formData.plexIP%>"<%}else{%><%=settings.plexIP%>"<%}%>>
                  <small id="plexIPHelp" class="form-text text-muted">Host for Plex, Jellyfin, Emby, or Kodi (same setting for all types).</small>
                </div>

                <div class="form-group">
                  <label for="plexIP">Server Port</label>
                  <input type="text" class="form-control" id="plexIPort" name="plexPort" aria-describedby="plexPortHelp"
                    placeholder="32400 / 8096" value="<% if(typeof formData !== 'undefined' && errors){%><%=formData.plexPort%>"<%}else{%><%=settings.plexPort%>"<%}%>>
                  <small id="plexPortHelp" class="form-text text-muted">Plex 32400; Jellyfin/Emby 8096; Kodi JSON-RPC often 8080.</small>
                </div>

                <div class="form-group">
                  <label for="plexToken">Token / API key</label>
                  <input type="password" class="form-control" name="plexToken" id="plexToken" aria-describedby="plexToken"
                    placeholder="Token or API key" value="<% if(typeof formData !== 'undefined' && errors){%><%=formData.plexToken%>"<%}else{%><%=settings.plexToken%>"<%}%>>
                  <small id="plexTokenHelp" class="form-text text-muted">Plex: <a href="https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/"
                      target="_blank">X-Plex-Token</a>. Jellyfin/Emby: API key. Kodi: optional HTTP auth (<code>kodi:password</code> or just password, user defaults to <code>kodi</code>).</small>
                </div>

                  <div class="form-group mt-3">
                    <label>Poster cache</label>
                    <div class="form-group">
                      <label for="posterCacheRefreshMins">Refresh poster DB &amp; images every (minutes)</label>
                      <input type="number" class="form-control" style="max-width: 8rem;" name="posterCacheRefreshMins" id="posterCacheRefreshMins" min="0" step="1"
                        value="<% if(typeof formData !== 'undefined' && errors && formData.posterCacheRefreshMins !== undefined){%><%=formData.posterCacheRefreshMins%><%}else{%><%=(settings.posterCacheRefreshMins != null ? settings.posterCacheRefreshMins : 0)%><%}%>">
                      <small class="form-text text-muted">0 = disabled. Uses the same interval as the maximum age: on each run, entries older than this many minutes are checked—images with a saved server URL are re-downloaded; others are removed until the library serves them again. Timer runs at least every 5 minutes when enabled.</small>
                    </div>
                    <div class="form-group">
                      <label for="posterCacheMinAgeBeforeChangeCheckMins">Minimum cache age before change checks (minutes)</label>
                      <input type="number" class="form-control" style="max-width: 8rem;" name="posterCacheMinAgeBeforeChangeCheckMins" id="posterCacheMinAgeBeforeChangeCheckMins" min="0" step="1"
                        value="<% if(typeof formData !== 'undefined' && errors && formData.posterCacheMinAgeBeforeChangeCheckMins !== undefined){%><%=formData.posterCacheMinAgeBeforeChangeCheckMins%><%}else{%><%=(settings.posterCacheMinAgeBeforeChangeCheckMins != null ? settings.posterCacheMinAgeBeforeChangeCheckMins : 0)%><%}%>">
                      <small class="form-text text-muted">0 = no extra wait. Otherwise a poster row must be at least this many minutes old (since it was last registered or refreshed) before we probe the media server for deleted items or re-download the image. New rows are left alone until they reach this age.</small>
                    </div>
                    <div class="form-group">
                      <div class="custom-control custom-control-nolabel custom-switch ml-auto">
                        <input type="checkbox" class="custom-control-input" name="preferCachedPosters" id="preferCachedPosters" value="true"
                          <% if(typeof formData !== 'undefined' && errors){%><%=(formData.preferCachedPosters == 'true') ? 'checked' : '' %><%}else{%><%=(settings.preferCachedPosters == 'true') ? 'checked' : '' %><%}%>>
                        <label class="custom-control-label" for="preferCachedPosters">Prefer cached poster library</label>
                      </div>
                      <small class="form-text text-muted">When on (default), slideshow library slides come from the poster cache and metadata database. Plex/Jellyfin/Emby/Kodi on-demand is only used if the cache is empty, and still runs in the background to fill the cache. Now Playing slides are unchanged.</small>
                    </div>
                    <div class="form-group">
                      <label for="cachedPosterSlideCount">Cached poster slide count</label>
                      <input type="number" class="form-control" style="max-width: 10rem;" name="cachedPosterSlideCount" id="cachedPosterSlideCount" min="1" step="1"
                        value="<% if(typeof formData !== 'undefined' && errors && formData.cachedPosterSlideCount !== undefined){%><%=formData.cachedPosterSlideCount%><%}else{%><%=(settings.cachedPosterSlideCount != null ? settings.cachedPosterSlideCount : 48)%><%}%>">
                      <small class="form-text text-muted">How many random cached titles to include per refresh when “Prefer cached poster library” is enabled. There is no fixed upper limit; you cannot get more distinct slides than you have poster rows on disk.</small>
